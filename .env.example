# ──────────────────────────────────────────────
# Spectral Instability Model — Environment Vars
# ──────────────────────────────────────────────
# Copy to .env and fill in values. See SETUP.md for registration steps.

# ACLED (Armed Conflict Location & Event Data)
# Register: https://acleddata.com/register/
ACLED_EMAIL=your_registered_email@institution.edu
ACLED_API_KEY=your_acled_api_key

# UCDP / PRIO (Uppsala Conflict Data Program)
# Request access token: see SETUP.md §4.1.2
# Optional: leave blank to use bulk CSV fallback
UCDP_API_TOKEN=

# UN Population Division
# Generate: https://population.un.org/dataportal/
UN_POP_BEARER_TOKEN=your_un_population_token

# FAO FAOSTAT
# Optional: leave blank to use bulk CSV download
FAOSTAT_JWT_TOKEN=

# UN Comtrade
# Subscribe: https://comtradeplus.un.org/
# Optional: leave blank to use IMF DOTS fallback
COMTRADE_SUBSCRIPTION_KEY=

# ──── Pipeline Configuration ────
# Set to true to use IMF DOTS instead of UN Comtrade for bilateral trade
USE_IMF_DOTS_FALLBACK=true

# Set to true to download the full V-Dem dataset (warning: ~1 GB)
VDEM_FULL_DOWNLOAD=false

# Random seed for reproducibility
RANDOM_SEED=42
